{
  "name": "@lxpanel/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build -w @lxpanel/shared && vite --host 127.0.0.1",
    "build": "npm run build -w @lxpanel/shared && tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build -w @lxpanel/shared && vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@lxpanel/shared": "0.1.0",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest"
  }
}
