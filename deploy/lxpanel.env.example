LXPANEL_HOST=127.0.0.1
LXPANEL_PORT=7080
LXPANEL_DATA_DIR=/var/lib/lxpanel
LXPANEL_SESSION_SECRET=replace-with-strong-random-secret
LXPANEL_COOKIE_SECURE=true
LXPANEL_ALLOWED_ORIGINS=https://panel.example.com
LXPANEL_IP_ALLOWLIST=127.0.0.1
LXPANEL_WEB_ROOT=/opt/lxpanel/apps/web/dist
LXPANEL_FILE_ROOTS=/srv;/var/www
LXPANEL_LOG_ROOTS=/var/log;/var/lib/lxpanel
LXPANEL_LOG_LEVEL=info
