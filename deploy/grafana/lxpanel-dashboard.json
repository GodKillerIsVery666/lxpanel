{
  "__inputs": [],
  "__requires": [],
  "title": "LXPanel 面板监控",
  "version": 2,
  "description": "面板自身关键指标：主机数、连接器数、审计事件、API 延迟、状态文件大小、资源使用率、告警事件趋势",
  "tags": ["lxpanel", "monitoring"],
  "schemaVersion": 39,
  "timezone": "browser",
  "panels": [
    {
      "title": "API 健康状态",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "targets": [{ "expr": "probe_success{job=\"lxpanel\"}", "legendFormat": "健康" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "title": "当前主机数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 0 },
      "targets": [{ "expr": "lxpanel_hosts_total", "legendFormat": "主机" }]
    },
    {
      "title": "连接器在线数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "targets": [{ "expr": "lxpanel_connectors_online", "legendFormat": "连接器" }]
    },
    {
      "title": "活跃告警数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "targets": [{ "expr": "lxpanel_alerts_active_total", "legendFormat": "告警" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 3, "color": "yellow" }, { "value": 10, "color": "red" }] }
        }
      }
    },
    {
      "title": "审计事件总数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "targets": [{ "expr": "lxpanel_audit_events_total", "legendFormat": "审计" }]
    },
    {
      "title": "状态文件大小",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 0 },
      "targets": [{ "expr": "lxpanel_state_bytes / 1024 / 1024", "legendFormat": "MB" }],
      "fieldConfig": {
        "defaults": {
          "unit": "MB",
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 10, "color": "red" }] }
        }
      }
    },
    {
      "title": "CPU 使用率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [{ "expr": "lxpanel_cpu_percent", "legendFormat": "CPU" }]
    },
    {
      "title": "内存使用率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "targets": [{ "expr": "lxpanel_memory_percent", "legendFormat": "内存" }]
    },
    {
      "title": "磁盘使用率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "targets": [{ "expr": "lxpanel_disk_percent", "legendFormat": "磁盘" }]
    },
    {
      "title": "API 响应时间 P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "histogram_quantile(0.99, rate(lxpanel_api_duration_seconds_bucket[5m]))", "legendFormat": "P99" }]
    },
    {
      "title": "API 响应时间 P50",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 12 },
      "targets": [{ "expr": "histogram_quantile(0.50, rate(lxpanel_api_duration_seconds_bucket[5m]))", "legendFormat": "P50" }]
    },
    {
      "title": "调度器延迟",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
      "targets": [{ "expr": "lxpanel_scheduler_tick_duration_ms", "legendFormat": "调度" }]
    },
    {
      "title": "告警事件趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "expr": "rate(lxpanel_alerts_warning_total[5m])", "legendFormat": "警告" },
        { "expr": "rate(lxpanel_alerts_critical_total[5m])", "legendFormat": "严重" }
      ]
    },
    {
      "title": "审计事件趋势",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [{ "expr": "rate(lxpanel_audit_events_total[5m])", "legendFormat": "审计事件" }]
    }
  ],
  "refresh": "30s"
}
